WEB_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_ORIGINS=http://localhost:8080
SHORT_URL_CACHE_TTL_SECONDS=43200

BACKEND_IMAGE=ghcr.io/abhidiwakar/url-shortener-nest-backend:latest
FRONTEND_IMAGE=ghcr.io/abhidiwakar/url-shortener-nest-frontend:latest

JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=1d

TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TRUST_PROXY=1

# Email (required in production; optional in local docker when SMTP_SKIP_SEND=true)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=moklay <your@gmail.com>
SMTP_SKIP_SEND=true

# Email verification
EMAIL_VERIFICATION_SKIP=false
EMAIL_VERIFICATION_OTP_TTL_SECONDS=600
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_RESENDS=5
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=3600

# Password reset
PASSWORD_RESET_OTP_TTL_SECONDS=600

# Legal pages and security.txt
SECURITY_CONTACT_EMAIL=security@diwakarit.com

# Admin activity notifications (registration, sign-in, URL shortened)
ADMIN_NOTIFY_EMAIL=hello@diwakarit.com
ADMIN_NOTIFY_ENABLED=true
NOTIFY_QUEUE_CONCURRENCY=5

# Redis Streams domain events
DOMAIN_EVENTS_STREAM=domain-events
DOMAIN_EVENTS_DLQ_STREAM=domain-events-dlq
DOMAIN_EVENTS_MAX_LEN=10000
STREAM_BLOCK_MS=5000
STREAM_CLAIM_IDLE_MS=30000
STREAM_RECLAIM_INTERVAL_MS=15000
STREAM_MAX_DELIVERIES=3
